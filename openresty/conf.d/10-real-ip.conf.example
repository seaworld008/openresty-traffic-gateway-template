# 如果你的入口层能够可靠透传真实客户端 IP，
# 可以复制本文件为 10-real-ip.conf 并按实际网络环境调整可信来源。
#
# 例如：
# cp openresty/conf.d/10-real-ip.conf.example openresty/conf.d/10-real-ip.conf
#
# 注意：
# - 只有在你确认上游 ELB / SLB / Ingress 会正确透传真实 IP 时才启用
# - 如果当前环境只能看到统一的内网 ELB IP，则不要启用

real_ip_header X-Forwarded-For;
real_ip_recursive on;

# 下面这些 set_real_ip_from 只是示例，请按真实网络拓扑收紧。
set_real_ip_from 127.0.0.1;
set_real_ip_from 10.0.0.0/8;
set_real_ip_from 172.16.0.0/12;
set_real_ip_from 192.168.0.0/16;
