# 本地静态站点模板
# 适合直接由 OpenResty 托管静态页面、构建产物或演示站点。

server {
    listen 80;
    server_name web.example.com;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        default_type text/plain;
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name web.example.com;

    # 静态站点也建议保留独立日志，便于区分静态资源和动态回源流量。
    access_log /var/log/openresty/web.example.com.access.log structured_json buffer=256k flush=1s;
    error_log  /var/log/openresty/web.example.com.error.log warn;

    ssl_certificate     /etc/letsencrypt/live/web.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/web.example.com/privkey.pem;
    include /etc/nginx/snippets/ssl-common.conf;
    include /etc/nginx/snippets/security-headers.conf;

    root /usr/local/openresty/nginx/html/static;
    index index.html;

    location /assets/ {
        # 这里给静态资源挂统一缓存策略，适合 CSS/JS/图片等强缓存文件。
        include /etc/nginx/snippets/cache-common.conf;
        try_files $uri =404;
    }

    location / {
        # 单页应用可保留 fallback 到 /index.html 的行为。
        try_files $uri $uri/ /index.html;
    }
}
