server {
    listen 80;
    server_name risk.example.com;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        default_type text/plain;
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name risk.example.com;

    access_log /var/log/openresty/risk.example.com.access.log structured_json buffer=256k flush=1s;
    error_log  /var/log/openresty/risk.example.com.error.log warn;

    set $gateway_policy risk_gateway;
    set $gateway_upstream frontend_backend;
    set $gateway_upstream_uri $request_uri;
    set $gateway_route risk_default;
    set $gateway_request_id "";
    set $gateway_client_ip "";
    set $gateway_circuit_state closed;
    set $gateway_gray_variant stable;

    ssl_certificate     /etc/letsencrypt/live/risk.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/risk.example.com/privkey.pem;
    include /etc/nginx/snippets/ssl-common.conf;
    include /etc/nginx/snippets/security-headers.conf;
    include /etc/nginx/snippets/gateway-phase-common.conf;

    location / {
        limit_req zone=per_ip_risk burst=8 nodelay;
        include /etc/nginx/snippets/proxy-common.conf;
        proxy_next_upstream_tries 2;
        proxy_pass http://$gateway_upstream$gateway_upstream_uri;
    }
}
