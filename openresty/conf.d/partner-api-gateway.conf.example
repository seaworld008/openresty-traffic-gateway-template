# 合作方 API 网关模板
# 适合需要 JWT / HMAC / Redis 元数据 / 动态路由的对接型 API。

server {
    listen 80;
    server_name partner-api.example.com;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        default_type text/plain;
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name partner-api.example.com;

    # 这个模板的行为主要由 gateway_policy 对应的 Lua 策略决定。
    access_log /var/log/openresty/partner-api.example.com.access.log structured_json buffer=256k flush=1s;
    error_log  /var/log/openresty/partner-api.example.com.error.log warn;

    # 复制模板时，优先改 policy、默认 upstream 和日志名。
    set $gateway_policy partner_api;
    set $gateway_upstream api_backend;
    set $gateway_upstream_uri $request_uri;
    set $gateway_route partner_default;
    set $gateway_request_id "";
    set $gateway_client_ip "";
    set $gateway_circuit_state closed;
    set $gateway_gray_variant stable;

    client_max_body_size 20m;

    ssl_certificate     /etc/letsencrypt/live/partner-api.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/partner-api.example.com/privkey.pem;
    include /etc/nginx/snippets/ssl-common.conf;
    include /etc/nginx/snippets/security-headers.conf;
    include /etc/nginx/snippets/gateway-phase-common.conf;

    location / {
        # 第一层策略会在 access/header/body/log 各阶段接管鉴权、改写和路由决策。
        include /etc/nginx/snippets/proxy-common.conf;
        proxy_next_upstream_tries 2;
        proxy_pass http://$gateway_upstream$gateway_upstream_uri;
    }
}
