server {
    listen 80;
    server_name REPLACE_WITH_DOMAIN;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        default_type text/plain;
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name REPLACE_WITH_DOMAIN;

    access_log /var/log/openresty/REPLACE_WITH_DOMAIN.access.log structured_json buffer=256k flush=1s;
    error_log  /var/log/openresty/REPLACE_WITH_DOMAIN.error.log warn;

    set $gateway_policy partner_api;
    set $gateway_upstream api_backend;
    set $gateway_upstream_uri $request_uri;
    set $gateway_route partner_default;
    set $gateway_request_id "";
    set $gateway_client_ip "";
    set $gateway_circuit_state closed;
    set $gateway_gray_variant stable;

    client_max_body_size 20m;

    ssl_certificate     /etc/letsencrypt/live/REPLACE_WITH_DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/REPLACE_WITH_DOMAIN/privkey.pem;
    include /etc/nginx/snippets/ssl-common.conf;
    include /etc/nginx/snippets/security-headers.conf;
    include /etc/nginx/snippets/gateway-phase-common.conf;

    location / {
        include /etc/nginx/snippets/proxy-common.conf;
        proxy_next_upstream_tries 2;
        proxy_pass http://$gateway_upstream$gateway_upstream_uri;
    }
}
