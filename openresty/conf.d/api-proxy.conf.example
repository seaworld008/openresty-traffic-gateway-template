# 普通 API 代理模板
# 适合不需要第一层 Lua 高级能力、只需要基础限流和回源的 API 场景。

server {
    listen 80;
    server_name api.example.com;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        default_type text/plain;
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    http2 on;
    server_name api.example.com;

    # API 日志建议单独拆分，后续分析 4xx/5xx 更直观。
    access_log /var/log/openresty/api.example.com.access.log structured_json buffer=256k flush=1s;
    error_log  /var/log/openresty/api.example.com.error.log warn;

    # 大请求场景可按接口实际情况单独调整。
    client_max_body_size 50m;

    ssl_certificate     /etc/letsencrypt/live/api.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.example.com/privkey.pem;
    include /etc/nginx/snippets/ssl-common.conf;
    include /etc/nginx/snippets/security-headers.conf;

    location / {
        # 普通 API 模板默认带基础限流，压测后可再调 burst 和 rate。
        limit_req zone=per_ip_api burst=40 nodelay;
        include /etc/nginx/snippets/proxy-common.conf;
        proxy_pass http://api_backend;
    }
}
