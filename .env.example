OPENRESTY_IMAGE=openresty/openresty:1.29.2.2-1-bookworm-fat
CERTBOT_IMAGE=certbot/certbot:v5.4.0
ECHO_BACKEND_IMAGE=mccutchen/go-httpbin:2.21.0

TZ=Asia/Shanghai
LETSENCRYPT_EMAIL=ops@example.com
WWW_DOMAIN=www.example.test
API_DOMAIN=api.example.test
ADMIN_DOMAIN=admin.example.test
STATIC_DOMAIN=static.example.test
RISK_GATEWAY_DOMAIN=risk-gateway.example.test
PARTNER_API_DOMAIN=partner-api.example.test
GRAY_RELEASE_DOMAIN=gray-release.example.test
ENROLL_DOMAIN=enroll.example.test

GATEWAY_REDIS_HOST=redis
GATEWAY_REDIS_PORT=6379
GATEWAY_REDIS_DB=0
GATEWAY_REDIS_PASSWORD=
GATEWAY_REDIS_TIMEOUT_MS=1000
GATEWAY_METADATA_CACHE_TTL_SECONDS=10
GATEWAY_GRAY_FLAG_CACHE_TTL_SECONDS=2
GATEWAY_RESPONSE_REWRITE_MAX_BYTES=262144
GATEWAY_QUEUE_SECRET=change-this-before-production
GATEWAY_ADMISSION_COOKIE_NAME=gw_admission
GATEWAY_OPS_TOKEN=change-this-before-production

# 设为 1 时，表示本地验证流程使用自签证书。
# 证书会写入 ./ssl/certbot/conf/live/<domain>/。
LOCAL_TEST_MODE=1
